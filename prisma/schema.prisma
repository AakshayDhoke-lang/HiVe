datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                    String         @id @default(uuid())
  googleId              String         @unique @map("google_id")
  email                 String         @unique
  name                  String
  avatarUrl             String?        @map("avatar_url")
  theme                 String         @default("system")
  refreshTokenEncrypted String?        @map("refresh_token_encrypted")
  createdAt             DateTime       @default(now()) @map("created_at")
  
  subjects              Subject[]
  pdfs                  Pdf[]
  conversations         Conversation[]
  aiConfig              AiConfig?
  
  @@map("users")
}

model Subject {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  name          String
  color         String
  isPublic      Boolean        @default(false) @map("is_public")
  publicApiKey  String?        @unique @map("public_api_key")
  createdAt     DateTime       @default(now()) @map("created_at")
  
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  pdfs          Pdf[]
  conversations Conversation[]
  
  @@map("subjects")
}

model Pdf {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  subjectId     String?  @map("subject_id")
  filename      String
  driveFileId   String   @map("drive_file_id")
  fileSize      Int      @map("file_size")
  extractedText String   @map("extracted_text") @db.Text
  source        String   @default("upload")
  status        String   @default("completed")
  createdAt     DateTime @default(now()) @map("created_at")
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  
  @@map("pdfs")
}

model Conversation {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  subjectId String?             @map("subject_id")
  title     String
  createdAt DateTime            @default(now()) @map("created_at")
  
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject?            @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  messages  Message[]
  shared    SharedConversation?
  
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  role           String       // "user" or "assistant"
  content        String       @db.Text
  sources        String?      @db.Text // stores sources as JSON string
  createdAt      DateTime     @default(now()) @map("created_at")
  
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@map("messages")
}

model AiConfig {
  userId          String   @id @map("user_id")
  providerType    String   @default("openai") @map("provider_type")
  baseUrl         String   @map("base_url")
  apiKeyEncrypted String?  @map("api_key_encrypted")
  model           String
  useClientSide   Boolean  @default(false) @map("use_client_side")
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("ai_configs")
}

model SharedConversation {
  id              String       @id @default(uuid())
  conversationId  String       @unique @map("conversation_id")
  userId          String       @map("user_id")
  slug            String       @unique
  createdAt       DateTime     @default(now()) @map("created_at")
  expiresAt       DateTime?    @map("expires_at")
  
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  @@map("shared_conversations")
}
